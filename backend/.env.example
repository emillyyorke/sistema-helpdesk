# Copie este arquivo para .env e ajuste os valores
# Para gerar uma SECRET_KEY forte: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-isto-por-uma-chave-secreta-aleatoria-bem-grande
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./helpdesk.db
# Em produção (Postgres): DATABASE_URL=postgresql://user:pass@host:5432/dbname
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# ===== Notificações por e-mail (opcional) =====
# Se SMTP_HOST estiver vazio, e-mails são silenciosamente ignorados.
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=seu@gmail.com SMTP_PASSWORD=senha-de-app-16-chars
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASSWORD=SG.xxxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
